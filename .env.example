# Public origin (no trailing slash). Local dev should use http://127.0.0.1:3000
PUBLIC_URL=http://127.0.0.1:3000

# Upstash Redis — required on Vercel for persistent OAuth sessions.
# Without these, sessions are stored in-memory (fine for local dev, breaks on redeploy).
# Add Upstash Redis via Vercel Marketplace — it auto-sets one of these env var patterns:
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   UPSTASH_KV_REST_API_URL / UPSTASH_KV_REST_API_TOKEN
#   KV_REST_API_URL / KV_REST_API_TOKEN
