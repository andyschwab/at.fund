{
  "lexicon": 1,
  "id": "fund.at.contribute",
  "description": "Declares contribution and funding entry points for an NSID namespace. Canonical schema for at.fund; supersedes com.contribute.tools.funding.",
  "defs": {
    "main": {
      "type": "record",
      "description": "Maps an NSID prefix to contribution entry points.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["appliesToNsidPrefix"],
        "properties": {
          "appliesToNsidPrefix": {
            "type": "string",
            "description": "Only collections whose NSID starts with this prefix are described by this record."
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "url"],
              "properties": {
                "label": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
              }
            }
          },
          "opencollective": {
            "type": "string",
            "format": "uri",
            "description": "Optional Open Collective URL."
          },
          "githubSponsors": {
            "type": "string",
            "description": "GitHub username or org slug for Sponsors."
          },
          "effectiveDate": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
